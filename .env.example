# ===== انسخ هذا الملف باسم .env واملأ القيم =====
# ⚠️ لا ترفع .env على GitHub أبداً (موجود بـ .gitignore).

# لغة النشر الافتراضيّة: ar أو en
POST_LANG=ar

# رابط مجلّد الصور العامّ (لإنستغرام لازم رابط صورة عامّ).
# مثال لو رفعت مجلّد output/images على مستودع GitHub عامّ:
# https://raw.githubusercontent.com/USERNAME/REPO/main/automation/output/images
BASE_URL=

# ===== Meta (فيسبوك + إنستغرام) =====
# من Meta for Developers → تطبيقك → Graph API
GRAPH_VERSION=v21.0
FB_PAGE_ID=
FB_PAGE_TOKEN=
IG_USER_ID=
# لو فاضي بيستعمل FB_PAGE_TOKEN
IG_TOKEN=

# ===== تيك توك (فيديو — يحتاج موافقة تطبيق) =====
TIKTOK_TOKEN=

# ===== تيليغرام (تنبيهات أحداث المباريات) =====
# التوكن من @BotFather، والـchat_id بتجيبه بـ: node match-bot/get-chat-id.js
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== بيانات كرة القدم (للمراقِب لاحقًا) =====
FOOTBALL_API_KEY=
